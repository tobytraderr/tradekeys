{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "packages": {
    "node": "20",
    "python": "3.11"
  },
  "steps": {
    "install": {
      "commands": [
        "npm ci",
        "python -m pip install --upgrade pip",
        "python -m pip install -r requirements.txt"
      ]
    },
    "build": {
      "inputs": [
        {
          "step": "install"
        }
      ],
      "commands": [
        "npm run build"
      ]
    }
  },
  "deploy": {
    "startCommand": "npm run start:railway"
  }
}
